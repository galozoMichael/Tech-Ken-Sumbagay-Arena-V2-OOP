<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            styleClass="character-pane"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.techken.ui.ProfileController">

    <!-- Title -->
    <Label text="PLAYER PROFILE"
           styleClass="title-select"
           alignment="CENTER"
           AnchorPane.topAnchor="40.0"
           AnchorPane.leftAnchor="0.0"
           AnchorPane.rightAnchor="0.0" />

    <!-- Back Button -->
    <Button fx:id="backBtn" text="◀ BACK"
            styleClass="back-btn"
            onAction="#backToMenu"
            AnchorPane.topAnchor="30.0"
            AnchorPane.leftAnchor="40.0" />

    <!-- Profile Info Panel -->
    <VBox spacing="24" alignment="CENTER"
          styleClass="info-panel"
          AnchorPane.topAnchor="140.0"
          AnchorPane.bottomAnchor="120.0"
          AnchorPane.leftAnchor="390.0"
          AnchorPane.rightAnchor="390.0">

        <!-- Clickable Name -->
        <Label fx:id="lblPlayerName"
               text="Player1"
               styleClass="char-name-text"
               maxWidth="Infinity"
               alignment="CENTER"
               wrapText="true"
               style="-fx-cursor: hand;" />

        <!-- Hint text -->
        <Label fx:id="lblClickHint"
               text="click name to edit"
               styleClass="char-bio-text"
               alignment="CENTER"
               maxWidth="Infinity"
               opacity="0.5" />

        <!-- Text field (hidden by default) -->
        <TextField fx:id="txtEditName"
                   promptText="Enter new name..."
                   alignment="CENTER"
                   maxWidth="300.0"
                   visible="false"
                   style="-fx-background-color: rgba(15,15,15,0.9);
                          -fx-text-fill: #FFD700;
                          -fx-border-color: #D4AF37;
                          -fx-border-width: 2;
                          -fx-font-size: 22px;
                          -fx-alignment: center;" />

        <!-- Stats Row -->
        <HBox spacing="40" alignment="CENTER">
            <Label fx:id="lblWins"
                   text="WINS: 0"
                   styleClass="char-stats-text"
                   alignment="CENTER" />
            <Label fx:id="lblLosses"
                   text="LOSSES: 0"
                   styleClass="char-stats-text"
                   alignment="CENTER" />
        </HBox>

        <!-- Win Rate -->
        <Label fx:id="lblWinRate"
               text="WIN RATE: 0.0%"
               styleClass="char-bio-text"
               maxWidth="Infinity"
               alignment="CENTER" />

    </VBox>

</AnchorPane>
