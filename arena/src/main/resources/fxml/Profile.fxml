<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            styleClass="character-pane"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.techken.ui.ProfileController">

    <!-- Title -->
    <Label text="PLAYER PROFILE"
           styleClass="title-select"
           alignment="CENTER"
           AnchorPane.topAnchor="40.0"
           AnchorPane.leftAnchor="0.0"
           AnchorPane.rightAnchor="0.0" />

    <!-- Back Button -->
    <Button fx:id="backBtn" text="◀ BACK"
            styleClass="back-btn"
            onAction="#backToMenu"
            AnchorPane.topAnchor="30.0"
            AnchorPane.leftAnchor="40.0" />

    <!-- Profile Info Panel -->
    <VBox spacing="24" alignment="CENTER"
          styleClass="info-panel"
          AnchorPane.topAnchor="140.0"
          AnchorPane.bottomAnchor="180.0"
          AnchorPane.leftAnchor="390.0"
          AnchorPane.rightAnchor="390.0">

        <Label fx:id="lblPlayerName"
               text="Player1"
               styleClass="char-name-text"
               maxWidth="Infinity"
               alignment="CENTER"
               wrapText="true"
               style="-fx-cursor: hand;" />

        <Label fx:id="lblClickHint"
               text="click name to edit"
               styleClass="char-bio-text"
               alignment="CENTER"
               maxWidth="Infinity"
               opacity="0.5" />

        <TextField fx:id="txtEditName"
                   promptText="Enter new name..."
                   alignment="CENTER"
                   maxWidth="300.0"
                   visible="false"
                   style="-fx-background-color: rgba(15,15,15,0.9);
                          -fx-text-fill: #FFD700;
                          -fx-border-color: #D4AF37;
                          -fx-border-width: 2;
                          -fx-font-size: 22px;
                          -fx-alignment: center;" />

        <HBox spacing="40" alignment="CENTER">
            <Label fx:id="lblWins"   text="WINS: 0"   styleClass="char-stats-text" alignment="CENTER" />
            <Label fx:id="lblLosses" text="LOSSES: 0" styleClass="char-stats-text" alignment="CENTER" />
        </HBox>

        <Label fx:id="lblWinRate"
               text="WIN RATE: 0.0%"
               styleClass="char-bio-text"
               maxWidth="Infinity"
               alignment="CENTER" />

    </VBox>

    <!-- Reset Profile Button -->
    <HBox spacing="20" alignment="CENTER"
          AnchorPane.bottomAnchor="60.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <Button fx:id="btnResetProfile" text="🗑 RESET PROFILE"
                styleClass="menu-btn"
                onAction="#showResetConfirm" />

    </HBox>

    <!-- In-Game Reset Confirmation Overlay (hidden by default) -->
    <VBox fx:id="resetConfirmPanel" visible="false"
          alignment="CENTER" spacing="20"
          styleClass="info-panel"
          AnchorPane.topAnchor="240.0"
          AnchorPane.bottomAnchor="240.0"
          AnchorPane.leftAnchor="390.0"
          AnchorPane.rightAnchor="390.0">

        <Label text="RESET PROFILE?"
               styleClass="char-name-text"
               alignment="CENTER"
               maxWidth="Infinity" />

        <Label text="This will set your wins and losses back to 0."
               styleClass="char-bio-text"
               alignment="CENTER"
               maxWidth="Infinity"
               wrapText="true" />

        <HBox spacing="20" alignment="CENTER">
            <Button text="✔ CONFIRM" styleClass="menu-btn" onAction="#confirmReset" />
            <Button text="✖ CANCEL"  styleClass="menu-btn" onAction="#cancelReset" />
        </HBox>

    </VBox>

</AnchorPane>
