<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>



<AnchorPane styleClass="root-pane" stylesheets="@../css/style.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techken.ui.MainMenuController">

    <VBox spacing="10" AnchorPane.leftAnchor="80.0" AnchorPane.topAnchor="80.0">

        <VBox spacing="-10">
            <Label styleClass="title-main" text="TECH-KEN" />
            <Label styleClass="title-sub" text="SUMBAGAY ARENA" />
        </VBox>

        <Region prefHeight="30" />

        <Button onAction="#Play" styleClass="menu-btn" fx:id="startBtn" text="START GAME" />
        <Button onAction="#CharacterSelect" styleClass="menu-btn" text="CHARACTER SELECT" />
        <Button onAction="#HowToPlay" styleClass="menu-btn" text="HOW TO PLAY" />
        <Button onAction="#Credits" styleClass="menu-btn" text="CREDITS" />
        <Button onAction="#Exit" styleClass="menu-btn" text="EXIT" />

    </VBox>

    <HBox spacing="20" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0">
        <Button onAction ="#Settings" styleClass="icon-btn" text="⚙ SETTINGS" />
    </HBox>

</AnchorPane>