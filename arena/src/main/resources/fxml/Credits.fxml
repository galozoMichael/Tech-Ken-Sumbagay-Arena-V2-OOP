<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            styleClass="root-pane"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.techken.ui.CreditsController">

    <VBox alignment="CENTER" spacing="30" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <Label text="DEVELOPER ROSTER" style="-fx-text-fill: #ff2e2e; -fx-font-size: 40px; -fx-font-weight: bold;" />

        <GridPane alignment="CENTER" hgap="40" vgap="20" style="-fx-background-color: rgba(0,0,0,0.8); -fx-padding: 40; -fx-border-color: #8b0000; -fx-border-width: 2;">
            <columnConstraints>
                <ColumnConstraints minWidth="100" />
                <ColumnConstraints minWidth="250" />
                <ColumnConstraints minWidth="200" />
            </columnConstraints>

            <children>
                <Label text="ID" textFill="#666" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label text="NAME" textFill="#666" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="ROLE" textFill="#666" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                <Label text="[DEV 1]" textFill="#ff2e2e" GridPane.rowIndex="1" />
                <Label text="[NAME HERE]" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label text="LEAD ARCHITECT" textFill="#ff2e2e" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <Label text="[DEV 2]" textFill="#ff2e2e" GridPane.rowIndex="2" />
                <Label text="[NAME HERE]" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label text="DATABASE ENG" textFill="#ff2e2e" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                <Label text="[DEV 3]" textFill="#ff2e2e" GridPane.rowIndex="3" />
                <Label text="[NAME HERE]" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Label text="UX RESEARCH" textFill="#ff2e2e" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                <Label text="[DEV 4]" textFill="#ff2e2e" GridPane.rowIndex="4" />
                <Label text="[NAME HERE]" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Label text="GAME LOGIC" textFill="#ff2e2e" GridPane.columnIndex="2" GridPane.rowIndex="4" />

                <Label text="[DEV 5]" textFill="#ff2e2e" GridPane.rowIndex="5" />
                <Label text="[NAME HERE]" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <Label text="INTEGRATION" textFill="#ff2e2e" GridPane.columnIndex="2" GridPane.rowIndex="5" />
            </children>
        </GridPane>

        <Button fx:id="returnBtn" text="RETURN" onAction="#returnFromCredits" styleClass="menu-btn" />

    </VBox>
</AnchorPane>